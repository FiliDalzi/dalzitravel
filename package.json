{
  "name": "dalzitravel",
  "version": "1.2.0",
  "description": "DalziTravel - AI-powered travel itinerary PWA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/css/styles.css --minify",
    "build:icons": "node scripts/generate-icons.js",
    "build": "npm run build:css && npm run build:icons",
    "railway:start": "npm run build && node server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "@tailwindcss/cli": "^4.3.1",
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "groq-sdk": "^0.9.0",
    "helmet": "^7.1.0",
    "pdfkit": "^0.19.1",
    "puppeteer-core": "^25.2.1",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
